.game-card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(166,138,91,0.2);
  transition: transform 0.15s;
}

.game-card.dark {
  background: #141414;
  border-color: rgba(200,169,126,0.15);
}

.game-card:active {
  transform: scale(0.98);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.type-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c2318;
}

.game-card.dark .type-name {
  color: #f0e8dc;
}

.status-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.status-tag.playing {
  background: rgba(166,138,91,0.15);
  color: #a68a5b;
}

.status-tag.finished {
  background: rgba(158,148,134,0.15);
  color: #9e9486;
}

.game-card.dark .status-tag.playing {
  background: rgba(200,169,126,0.2);
  color: #c8a97e;
}

.game-card.dark .status-tag.finished {
  background: rgba(122,122,122,0.2);
  color: #7a7a7a;
}

.card-time {
  font-size: 24rpx;
  color: #9e9486;
}

.game-card.dark .card-time {
  color: #7a7a7a;
}

.card-body {
  margin-bottom: 12rpx;
}

.players-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.player-name {
  font-size: 24rpx;
  color: #2c2318;
  background: #f5f0e8;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
}

.game-card.dark .player-name {
  color: #f0e8dc;
  background: #1e1e1e;
}

.info-row {
  display: flex;
  gap: 16rpx;
}

.info-item {
  font-size: 24rpx;
  color: #9e9486;
}

.game-card.dark .info-item {
  color: #7a7a7a;
}

.card-footer {
  display: flex;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(166,138,91,0.2);
}

.game-card.dark .card-footer {
  border-top-color: rgba(200,169,126,0.15);
}

.footer-label {
  font-size: 24rpx;
  color: #9e9486;
}

.game-card.dark .footer-label {
  color: #7a7a7a;
}

.footer-value {
  font-size: 24rpx;
  color: #8b6914;
  font-weight: 600;
}

.game-card.dark .footer-value {
  color: #d4af37;
}
