page {
  background: #f5f0e8;
}

.container {
  --bg-deep: #f5f0e8;
  --bg-card: #ffffff;
  --gold: #a68a5b;
  --gold-bright: #8b6914;
  --gold-dim: #c4a97a;
  --cream: #2c2318;
  --text-dim: #9e9486;
  --border: rgba(166,138,91,0.2);

  padding: 24rpx;
  min-height: 100vh;
  background: var(--bg-deep);
  font-family: 'PingFang SC', 'Microsoft YaHei', 'SimHei', sans-serif;
}

.container.dark {
  --bg-deep: #0a0a0a;
  --bg-card: #141414;
  --gold: #c8a97e;
  --gold-bright: #d4af37;
  --gold-dim: #a08c6a;
  --cream: #f0e8dc;
  --text-dim: #7a7a7a;
  --border: rgba(200,169,126,0.15);

  background: var(--bg-deep);
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 16rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid var(--border);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--cream);
}

.search-placeholder {
  color: var(--text-dim);
}

.search-clear {
  font-size: 28rpx;
  color: var(--text-dim);
  padding: 8rpx 12rpx;
}

.search-icon {
  font-size: 28rpx;
  color: var(--gold);
  padding-left: 12rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.filter-tags {
  display: flex;
  flex: 1;
  gap: 12rpx;
}

.filter-tag {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  background: var(--bg-card);
  color: var(--text-dim);
  border: 1rpx solid var(--border);
  white-space: nowrap;
}

.filter-tag.active {
  background: linear-gradient(135deg, var(--gold) 0%, #8b6914 100%);
  color: #fff;
  border-color: var(--gold);
}

.container.dark .filter-tag.active {
  color: #0a0a0a;
}

/* 日期筛选 */
.date-picker {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  border: 1rpx solid var(--border);
  white-space: nowrap;
}

.date-text {
  font-size: 24rpx;
  color: var(--cream);
}

.date-clear {
  font-size: 32rpx;
  color: var(--text-dim);
  padding: 0 4rpx;
  margin-left: 8rpx;
}

/* 牌局列表 */
.game-list {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-dim);
  display: block;
  margin-bottom: 32rpx;
}

.empty-action {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, var(--gold) 0%, #8b6914 100%);
  border-radius: 8rpx;
}

.empty-action text {
  color: #fff;
  font-size: 28rpx;
}

.container.dark .empty-action text {
  color: #0a0a0a;
}
